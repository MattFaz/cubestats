# Auth — replace before running with NODE_ENV=production.
# The server refuses to start if these match known-insecure values
# (e.g. "changeme", "admin", "password", or any "change-this*" / "dev-secret*" / "changeme*" string).
NUXT_AUTH_PASS=replace-me
NUXT_AUTH_SECRET=replace-me-with-a-long-random-string

# Optional
APP_PORT=3000
# NUXT_DATABASE_PATH=/app/data/cubestats.db   # default in the docker image; override to relocate the SQLite file
