# Postgres service (used by the postgres container)
POSTGRES_DB=cubestats
POSTGRES_USER=cubestats
POSTGRES_PASSWORD=cubestats

# Database connection (used by the Nuxt server and by drizzle-kit migrations)
NUXT_DATABASE_URL=postgres://cubestats:cubestats@localhost:5432/cubestats

# Auth — replace before running with NODE_ENV=production.
# The server refuses to start if these match known-insecure values
# (e.g. "changeme", "admin", "password", or any "change-this*" / "dev-secret*" / "changeme*" string).
NUXT_AUTH_USER=admin
NUXT_AUTH_PASS=replace-me
NUXT_AUTH_SECRET=replace-me-with-a-long-random-string

# App
APP_PORT=3000
