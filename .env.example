# Database (Docker Compose uses POSTGRES_* vars; Nuxt needs NUXT_DATABASE_URL)
DATABASE_URL=postgres://cubestats:cubestats@localhost:5432/cubestats
NUXT_DATABASE_URL=postgres://cubestats:cubestats@localhost:5432/cubestats
POSTGRES_DB=cubestats
POSTGRES_USER=cubestats
POSTGRES_PASSWORD=cubestats

# Auth (Nuxt needs NUXT_ prefix for runtimeConfig; non-prefixed used by Docker Compose)
AUTH_USER=admin
NUXT_AUTH_USER=admin
AUTH_PASS=changeme
NUXT_AUTH_PASS=changeme
AUTH_SECRET=change-this-to-a-random-string
NUXT_AUTH_SECRET=change-this-to-a-random-string

# App
APP_PORT=3000
